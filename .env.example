# ─── Firebase (Auth only — Storage is Supabase) ─────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Base URL only (no /rest/v1/ suffix - the client handles that)
SUPABASE_URL=https://your-project.supabase.co
# Service role JWT key from Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── NVIDIA NIM ───────────────────────────────────────────────────────────────
# Key for:  nvidia/nemotron-3-ultra-550b-a55b  (rewrite, coverletter, interview)
NVIDIA_API_KEY_NEMOTRON=nvapi-...
# Key for:  mistralai/mistral-nemotron          (extract, match)
NVIDIA_API_KEY_MISTRAL=nvapi-...

# ─── Tavily ───────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Redis ────────────────────────────────────────────────────────────────────
# LOCAL: Use local Redis container (docker-compose)
REDIS_URL=redis://redis:6379/0

# PRODUCTION: Upstash Redis with SSL (requires ssl_cert_reqs parameter)
# REDIS_URL=rediss://default:PASSWORD@your-redis.upstash.io:6379?ssl_cert_reqs=CERT_REQUIRED

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS_STR=http://localhost:5173
